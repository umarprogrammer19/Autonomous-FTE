# Email Environment Variables
EMAIL_ADDRESS=xxxxxxxxxxxxxxx
EMAIL_APP_PASSWORD=xxxxxxxxxxxxxxx
SMTP_SERVER=xxxxxxxxxxxxxxx
SMTP_PORT=xxxxxxxxxxxxxxx

# WhatsApp Automation System
# Environment Variables Configuration
# Your whapi.cloud API token
WHAPI_TOKEN=xxxxxxxxxxxxxxx

# Base URL for whapi.cloud API (default: https://gate.whapi.cloud)
WHAPI_BASE_URL=xxxxxxxxxxxxxxx
# Port for webhook server (only used if USE_WEBHOOK=true)
WEBHOOK_PORT=xxxxxxxxxxxxxxx
# Polling interval in seconds (used when not using webhooks)
POLLING_INTERVAL=xxxxxxxxxxxxxxx
# Enable webhook mode (true/false)
USE_WEBHOOK=xxxxxxxxxxxxxxx